{
  "$schema": "https://example.com/flider/design-tokens.schema.json",
  "meta": {
    "name": "Flider Design Tokens",
    "version": "1.0.0-rc2.1",
    "description": "Core UI tokens and curated 4x4 vibe matrix extracted from Flider."
  },
  "core": {
    "color": {
      "bg": "#050505",
      "surface": "#121212",
      "surfaceLight": "#1e1e1e",
      "textPrimary": "#ffffff",
      "textSecondary": "#a0a0a0",
      "accent": "#ffffff",
      "accentHover": "#e0e0e0",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderHover": "rgba(255, 255, 255, 0.2)"
    },
    "font": {
      "sans": "'Space Mono', monospace",
      "serif": "'Playfair Display', serif",
      "mono": "'Space Mono', monospace"
    },
    "radius": {
      "sm": "8px",
      "md": "12px",
      "lg": "16px",
      "pill": "50px"
    },
    "motion": {
      "fast": "0.2s cubic-bezier(0.4, 0, 0.2, 1)",
      "smooth": "0.4s cubic-bezier(0.25, 1, 0.5, 1)"
    },
    "shadow": {
      "buttonHover": "0 10px 20px rgba(255, 255, 255, 0.1)",
      "cardHover": "0 10px 20px rgba(0, 0, 0, 0.2)"
    },
    "spacing": {
      "xs": "0.5rem",
      "sm": "0.75rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2.5rem"
    }
  },
  "typography": {
    "h1": {
      "fontSize": "clamp(2.5rem, 5vw, 4rem)",
      "lineHeight": "1.1",
      "letterSpacing": "-0.02em",
      "fontFamily": "var(--fs-font-serif)",
      "fontWeight": 400
    },
    "h2": {
      "fontSize": "clamp(2rem, 4vw, 3rem)",
      "lineHeight": "1.2",
      "letterSpacing": "-0.02em",
      "fontFamily": "var(--fs-font-serif)",
      "fontWeight": 400
    },
    "body": {
      "fontSize": "1.1rem",
      "lineHeight": "1.5",
      "fontFamily": "var(--fs-font-sans)"
    }
  },
  "styles": {
    "brachial": {
      "name": "Brachial",
      "description": "Laut, kontrastreich, industriell",
      "themeClass": "theme-brachial",
      "previewClass": "preview-brachial"
    },
    "minimalist": {
      "name": "Minimalist",
      "description": "Ruhig, elegant, inhaltsfokussiert",
      "themeClass": "theme-minimalist",
      "previewClass": "preview-minimalist"
    },
    "modern": {
      "name": "Modern",
      "description": "Clean, tech-affin, vertrauenswuerdig",
      "themeClass": "theme-modern",
      "previewClass": "preview-modern"
    },
    "classic": {
      "name": "Classic",
      "description": "Zeitlos, wertig, erzaehlend",
      "themeClass": "theme-classic",
      "previewClass": "preview-classic"
    }
  },
  "vibes": {
